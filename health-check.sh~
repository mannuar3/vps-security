#!/bin/bash
# VPS Security Toolkit Health Check with Self-Healing

LOGFILE="~/vps-security/vps-security.log"
REPORT="~/vps-security/weekly-report.html"
CRON_TEMPLATE="~/vps-security/cron-template.txt"

echo "=== Health Check: $(date '+%Y-%m-%d %H:%M:%S') ==="

# --- Cron Jobs ---
echo "🔔 Checking cron jobs..."
CRON_JOBS=$(crontab -l | grep vps-security)
if [ -n "$CRON_JOBS" ]; then
    echo "✅ Found cron jobs:"
    echo "$CRON_JOBS"
else
    echo "❌ No cron jobs found for vps-security"
    if [ -f "$CRON_TEMPLATE" ]; then
        echo "⚙️ Restoring cron jobs from template..."
        crontab $CRON_TEMPLATE
        echo "✅ Cron jobs restored"
    else
        echo "⚠️ No cron template found at $CRON_TEMPLATE"
    fi
fi

# --- Log Rotation ---
echo ""
echo "📂 Checking log rotation..."
if [ -f "$LOGFILE" ]; then
    SIZE=$(stat -c%s "$LOGFILE")
    echo "Log size: $SIZE bytes"
    if [ $SIZE -lt 1048576 ]; then
        echo "✅ Log file under 1MB (rotation working)"
    else
        echo "⚠️ Log file exceeds 1MB, rotating now..."
        mv "$LOGFILE" "${LOGFILE}.$(date '+%Y%m%d-%H%M%S').bak"
        echo "$(date '+%Y-%m-%d %H:%M:%S') - Log rotated by health check" > "$LOGFILE"
        echo "✅ Log rotated"
    fi
else
    echo "❌ Log file not found, creating new..."
    echo "$(date '+%Y-%m-%d %H:%M:%S') - New log created by health check" > "$LOGFILE"
    echo "✅ Log file created"
fi

# --- Notifier Activity ---
echo ""
echo "📧 Checking notifier activity..."
LAST_NOTIFY=$(grep "Report emailed" $LOGFILE | tail -n 1)
LAST_SLACK=$(grep "Report posted to Slack" $LOGFILE | tail -n 1)
LAST_TEAMS=$(grep "Report posted to Teams" $LOGFILE | tail -n 1)

if [ -n "$LAST_NOTIFY" ]; then
    echo "✅ Email notifier ran: $LAST_NOTIFY"
else
    echo "❌ No email notifier entries found"
fi

if [ -n "$LAST_SLACK" ]; then
    echo "✅ Slack notifier ran: $LAST_SLACK"
else
    echo "❌ No Slack notifier entries found"
fi

if [ -n "$LAST_TEAMS" ]; then
    echo "✅ Teams notifier ran: $LAST_TEAMS"
else
    echo "❌ No Teams notifier entries found"
fi

# --- Report File ---
echo ""
echo "📊 Checking weekly report file..."
if [ -f "$REPORT" ]; then
    echo "✅ Weekly report exists: $REPORT"
else
    echo "❌ Weekly report file missing, regenerating..."
    ~/vps-security/generate-report.sh
    echo "✅ Weekly report regenerated"
fi

echo ""
echo "Health check complete."

